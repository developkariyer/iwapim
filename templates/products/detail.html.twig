{# templates/products/detail.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Product Detail{% endblock %}

{% block content %}
    <div class="card card-custom">
        {% if product.picture %}
            <img src="{{ product.picture.getThumbnail('default') }}" class="card-img-top" alt="{{ product.name }}">
        {% endif %}
        <div class="card-body">
            <h1 class="card-title">{{ product.name }}</h1>
            <p class="card-text">{{ product.description }}</p>
            <p><strong>Product Code:</strong> {{ product.productCode }}</p>
            <p><strong>Product Class:</strong> {{ product.productClass }}</p>
            <p><strong>Dimensions:</strong> {{ product.productWidth }} x {{ product.productHeight }} x {{ product.productDepth }}</p>
            <p><strong>Weight:</strong> {{ product.productWeight }}</p>
        </div>
    </div>
{% endblock %}

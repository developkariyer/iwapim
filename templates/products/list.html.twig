{# templates/products/list.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Products List{% endblock %}

{% block content %}
    <h1>Products</h1>
    <ul class="list-group">
        {% for product in products %}
            <li class="list-group-item">
                <a href="{{ path('product_detail', {'id': product.id}) }}">
                    {{ product.name }}
                </a>
            </li>
        {% endfor %}
    </ul>
{% endblock %}

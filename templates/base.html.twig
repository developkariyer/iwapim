{# templates/base.html.twig #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}My Website{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('bundles/bootstrap/css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ asset('bundles/bootstrap/font/bootstrap-icons.css') }}">
    {% block stylesheets %}
    {% endblock %}
    <style>
        .search-bar {
            max-width: 600px;
            margin: 2rem auto;
        }
        .card-custom {
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            margin-bottom: 1.5rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <form class="search-bar">
            <div class="input-group">
                <input type="text" class="form-control" placeholder="Ürün ara...">
                <button class="btn btn-primary" type="button"><i class="bi bi-search"></i></button>
            </div>
        </form>

        {% block content %}
        {% endblock %}
    </div>

    <script src="{{ asset('bundles/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.3/dist/umd/popper.min.js"></script>
    {% block javascripts %}
    {% endblock %}
</body>
</html>
